@using MealPlanner.Web.Extensions
@model MealPlanner.Application.DTOs.Recipes.RecipeDto

@if (Model.Ingredients.Any())
{
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        @foreach (var ingredient in Model.Ingredients)
        {
            <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg">
                <div class="flex-shrink-0 w-2 h-2 bg-primary-500 rounded-full"></div>
                <div class="flex-1">
                    <span class="font-medium text-gray-900">@ingredient.Quantity.FormatWithUnit(ingredient.Unit)</span>
                    <span class="text-gray-700">@ingredient.IngredientName</span>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-8 text-gray-500">
        <p>No ingredients added yet</p>
    </div>
}

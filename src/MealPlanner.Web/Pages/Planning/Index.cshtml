@page
@model MealPlanner.Web.Pages.Planning.IndexModel
@{
    ViewData["Title"] = "Planning";
}

<div class="space-y-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Planning</h1>
        <p class="text-gray-500 mt-1">Manage your meal plan and shopping list.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a asp-area="" asp-page="/MealPlans/Index"
           class="bg-white rounded-lg shadow p-6 hover:shadow-md transition-shadow flex items-start space-x-4">
            <div class="bg-primary-100 rounded-lg p-3 flex-shrink-0">
                <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
            </div>
            <div>
                <h2 class="text-lg font-semibold text-gray-900">Meal Plan</h2>
                <p class="text-gray-500 text-sm mt-1">Plan your meals for the week.</p>
            </div>
        </a>

        <a asp-area="" asp-page="/Shopping/Index"
           class="bg-white rounded-lg shadow p-6 hover:shadow-md transition-shadow flex items-start space-x-4">
            <div class="bg-primary-100 rounded-lg p-3 flex-shrink-0">
                <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
            </div>
            <div>
                <h2 class="text-lg font-semibold text-gray-900">Shopping List</h2>
                <p class="text-gray-500 text-sm mt-1">View and manage your shopping list.</p>
            </div>
        </a>
    </div>
</div>

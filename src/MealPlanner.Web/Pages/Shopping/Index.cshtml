@page
@using MealPlanner.Domain.Enums
@model MealPlanner.Web.Pages.Shopping.IndexModel
@{
    ViewData["Title"] = "Shopping List";
}

@Html.AntiForgeryToken()

<div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Shopping List</h1>
            <p class="text-gray-600 mt-1">Manage your grocery list for the week.</p>
        </div>
        @if (Model.CurrentShoppingList != null)
        {
            <form method="post" asp-page-handler="Delete" asp-route-id="@Model.CurrentShoppingList.Id" onsubmit="return confirm('Are you sure you want to clear the list?')">
                <button type="submit" class="inline-flex items-center px-4 py-2 border border-red-300 text-red-700 bg-white rounded-lg hover:bg-red-50 transition-colors">
                    <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                    Clear List
                </button>
            </form>
        }
    </div>

    @if (Model.CurrentShoppingList == null)
    {
        <!-- Empty State & Generate Section -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 text-center">
            <div class="mx-auto h-20 w-20 text-gray-300 mb-4">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900">No active shopping list</h3>
            <p class="text-gray-600 mt-2 mb-8">Generate a list from your meal plan to get started.</p>
        </div>
        <div>
            @if (Model.RecentMealPlans.Any())
            {
                <h3 class="text-lg font-semibold text-gray-700 mb-3">Generate from a meal plan</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                    @foreach (var plan in Model.RecentMealPlans)
                    {
                        <div class="border border-gray-200 rounded-lg p-4 hover:border-primary-300 hover:bg-primary-50 transition-all text-left">
                            <h4 class="font-bold text-gray-900">Week of @plan.WeekStartDate.ToShortDateString()</h4>
                            <p class="text-sm text-gray-500 mb-4">@plan.PlannedMeals.Count() @(plan.PlannedMeals.Count() == 1 ? "meal" : "meals") planned</p>
                            <form method="post" asp-page-handler="Generate" asp-route-mealPlanId="@plan.Id">
                                <button type="submit" class="w-full py-2 bg-primary-600 text-white rounded-md hover:bg-primary-700 transition-colors font-medium">
                                    Generate List
                                </button>
                            </form>
                        </div>
                    }
                </div>
            }
            else
            {
                <a asp-page="/MealPlans/Index" class="inline-flex items-center px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium">
                    Go to Meal Planner
                </a>
            }
        </div>
    }
    else
    {
        <!-- Shopping List View -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Main List -->
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                    <div class="p-4 bg-gray-50 border-b border-gray-200">
                        <h3 class="font-bold text-gray-900">Items</h3>
                    </div>
                    <div class="divide-y divide-gray-100">
                        @{
                            var groupedItems = Model.CurrentShoppingList.Items
                                .OrderBy(i => i.IsChecked)
                                .GroupBy(i => i.IngredientCategory ?? "Other")
                                .OrderBy(g => g.Key);
                        }
                        @foreach (var group in groupedItems)
                        {
                            <div class="bg-gray-50/50 px-4 py-2">
                                <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">@group.Key</span>
                            </div>
                            @foreach (var item in group)
                            {
                                <partial name="_ShoppingListItem" model="item" view-data='@new ViewDataDictionary(ViewData) { { "listId", Model.CurrentShoppingList.Id } }' />
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Sidebar: Add Manual Item + Generate from Meal Plan -->
            <div class="space-y-6">
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                    <h3 class="font-bold text-gray-900 mb-4">Add Extra Item</h3>
                    <form method="post" asp-page-handler="AddItem" asp-route-listId="@Model.CurrentShoppingList.Id" class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Ingredient</label>
                            <select asp-for="NewItem.IngredientId" class="w-full rounded-lg border-gray-300 focus:ring-primary-500 focus:border-primary-500">
                                <option value="">Select an ingredient...</option>
                                @foreach (var ing in Model.AvailableIngredients)
                                {
                                    <option value="@ing.Id">@ing.Name</option>
                                }
                            </select>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Quantity</label>
                                <input asp-for="NewItem.Quantity" type="number" step="0.1" class="w-full rounded-lg border-gray-300 focus:ring-primary-500 focus:border-primary-500" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Unit</label>
                                <select asp-for="NewItem.Unit" asp-items="Html.GetEnumSelectList<MeasurementUnit>()" class="w-full rounded-lg border-gray-300 focus:ring-primary-500 focus:border-primary-500"></select>
                            </div>
                        </div>
                        <button type="submit" class="w-full py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium">
                            Add to List
                        </button>
                    </form>
                </div>

                @if (Model.RecentMealPlans.Any())
                {
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                        <h3 class="font-bold text-gray-900 mb-4">Add from Meal Plan</h3>
                        <div class="space-y-3">
                            @foreach (var plan in Model.RecentMealPlans)
                            {
                                <div class="border border-gray-200 rounded-lg p-3 hover:border-primary-300 hover:bg-primary-50 transition-all">
                                    <p class="font-semibold text-gray-900 text-sm">Week of @plan.WeekStartDate.ToShortDateString()</p>
                                    <p class="text-xs text-gray-500 mb-2">@plan.PlannedMeals.Count() @(plan.PlannedMeals.Count() == 1 ? "meal" : "meals") planned</p>
                                    <form method="post" asp-page-handler="Generate" asp-route-mealPlanId="@plan.Id">
                                        <button type="submit" class="w-full py-1.5 bg-primary-600 text-white rounded-md hover:bg-primary-700 transition-colors font-medium text-sm">
                                            Merge into List
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@page
@model MealPlanner.Web.Pages.Food.IndexModel
@{
    ViewData["Title"] = "Food";
}

<div class="space-y-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Food</h1>
        <p class="text-gray-500 mt-1">Manage your recipes and pantry.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a asp-area="" asp-page="/Recipes/Index"
           class="bg-white rounded-lg shadow p-6 hover:shadow-md transition-shadow flex items-start space-x-4">
            <div class="bg-primary-100 rounded-lg p-3 flex-shrink-0">
                <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
            </div>
            <div>
                <h2 class="text-lg font-semibold text-gray-900">Recipes</h2>
                <p class="text-gray-500 text-sm mt-1">Browse and manage your recipe collection.</p>
            </div>
        </a>

        <a asp-area="" asp-page="/Pantry/Index"
           class="bg-white rounded-lg shadow p-6 hover:shadow-md transition-shadow flex items-start space-x-4">
            <div class="bg-primary-100 rounded-lg p-3 flex-shrink-0">
                <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                </svg>
            </div>
            <div>
                <h2 class="text-lg font-semibold text-gray-900">Pantry</h2>
                <p class="text-gray-500 text-sm mt-1">Track what you have at home.</p>
            </div>
        </a>
    </div>
</div>

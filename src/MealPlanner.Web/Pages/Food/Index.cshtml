@page
@model MealPlanner.Web.Pages.Food.IndexModel
@{
    ViewData["Title"] = "Food";
}

<div class="space-y-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Food</h1>
        <p class="text-gray-500 mt-1">Manage your pantry and recipes.</p>
    </div>

    <!-- Pantry Widget -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="p-4 border-b border-gray-200 flex items-center justify-between">
            <h2 class="font-semibold text-gray-900">Pantry</h2>
            <!--
                hx-get: fetches the add form partial from OnGetAddFormAsync
                hx-target: swaps the form into the #pantry-add-slot div below
                hx-swap: replaces the contents of the target
            -->
            <button hx-get="@Url.Page("Index", "AddForm")"
                    hx-target="#pantry-add-slot"
                    hx-swap="innerHTML"
                    class="text-sm font-medium text-primary-600 hover:text-primary-700">
                + Add Item
            </button>
        </div>

        <!-- This is where the add form will appear when the button is clicked -->
        <div id="pantry-add-slot"></div>

        <!-- Empty state (hidden once items exist) -->
        @if (Model.CurrentPantry == null || !Model.CurrentPantry.Items.Any())
        {
            <div id="pantry-empty-state" class="p-8 text-center text-gray-400">
                <p class="text-sm">No items in your pantry yet.</p>
            </div>
        }

        <!-- Item list -->
        <div id="pantry-item-list" class="divide-y divide-gray-100">
            @if (Model.CurrentPantry != null)
            {
                @foreach (var item in Model.CurrentPantry.Items)
                {
                    <partial name="_PantryListItem" model="item" />
                }
            }
        </div>
    </div>

    <!-- Recipes link -->
    <a asp-page="/Recipes/Index"
       class="block bg-white rounded-xl shadow-sm border border-gray-200 p-4 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="font-semibold text-gray-900">Recipes</h2>
                <p class="text-sm text-gray-500 mt-1">Browse and manage your recipe collection.</p>
            </div>
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
        </div>
    </a>
</div>
